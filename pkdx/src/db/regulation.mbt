///|
/// レギュレーションで使用可能かを判定する。
/// regulation が空文字列の場合は全ポケモン使用可。
/// 未知のレギュレーション名の場合も全ポケモン使用可。
pub fn is_available(global_no : String, regulation : String) -> Bool {
  if regulation == "" {
    return true
  }
  match regulation {
    "M-A" => {
      let nos = ma_global_nos()
      for i = 0; i < nos.length(); i = i + 1 {
        if nos[i] == global_no {
          return true
        }
      }
      false
    }
    _ => true
  }
}

///|
/// 利用可能なレギュレーション名のリストを返す。
pub fn available_regulations() -> Array[String] {
  ["M-A"]
}
